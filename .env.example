PORT=5000

# Option 1 (recommended locally): path to a Firebase service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Option 2 (recommended for Render): full service account JSON as one env var
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Option 3: base64-encoded service account JSON
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# Option 4: split credentials
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# Firestore location for your app state document
FIRESTORE_COLLECTION=gtc
FIRESTORE_DOC=appData
